{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mops.local/schema/model-edit.schema.json",
  "title": "mops model edit batch",
  "type": "object",
  "additionalProperties": false,
  "required": ["operations"],
  "properties": {
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/setPropertyOperation"
      }
    }
  },
  "$defs": {
    "nodeReferenceTarget": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "description": "Serialized MPS node reference.",
          "examples": [
            "r:fd752404-89d3-4ffe-bc3a-7fb7a27c63b6(com.specificlanguages.json.structure)/2110045694544566904"
          ]
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["nodeReference"],
          "properties": {
            "nodeReference": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["model", "nodeId"],
          "properties": {
            "model": {
              "type": "string",
              "minLength": 1,
              "description": "Model reference or model path."
            },
            "nodeId": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["modelTarget", "nodeId"],
          "properties": {
            "modelTarget": {
              "type": "string",
              "minLength": 1,
              "description": "Legacy model target spelling kept for compatibility."
            },
            "nodeId": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "setPropertyOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["op", "target", "name"],
      "properties": {
        "op": {
          "const": "setProperty"
        },
        "target": {
          "$ref": "#/$defs/nodeReferenceTarget"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": ["string", "null"]
        }
      },
      "examples": [
        {
          "op": "setProperty",
          "target": "r:fd752404-89d3-4ffe-bc3a-7fb7a27c63b6(com.specificlanguages.json.structure)/2110045694544566904",
          "name": "name",
          "value": "RenamedJsonFile"
        },
        {
          "op": "setProperty",
          "target": {
            "model": "/absolute/path/to/model.mps",
            "nodeId": "2110045694544566904"
          },
          "name": "conceptAlias"
        }
      ]
    }
  },
  "examples": [
    {
      "operations": [
        {
          "op": "setProperty",
          "target": "r:fd752404-89d3-4ffe-bc3a-7fb7a27c63b6(com.specificlanguages.json.structure)/2110045694544566904",
          "name": "name",
          "value": "RenamedJsonFile"
        }
      ]
    },
    {
      "operations": [
        {
          "op": "setProperty",
          "target": {
            "model": "/absolute/path/to/model.mps",
            "nodeId": "2110045694544566904"
          },
          "name": "conceptAlias"
        }
      ]
    }
  ]
}
